# Copy to secrets.yml (gitignored) and encrypt: `ansible-vault encrypt secrets.yml`.
# Then run the playbook with --ask-vault-pass. Same pattern as playbooks/loadbalancer/.

# Hetzner Object Storage keys — the SAME ones used by terraform/backups/, which creates the bucket.
# Hetzner Console -> Object Storage -> Manage credentials.
pgbackrest_s3_access_key: CHANGEME_hetzner_s3_key
pgbackrest_s3_secret_key: CHANGEME_hetzner_s3_secret

# Must equal `backup_bucket` in terraform/backups/terraform.tfvars — that module creates this bucket,
# pgBackRest writes to it. Hetzner bucket names are GLOBALLY unique, so pick something specific to
# you ("db-backups" is long since taken). `./up init` derives one from your domain.
pgbackrest_s3_bucket: CHANGEME_db_backups_yourdomain_com

# Encrypts the repository at rest. Generate one: `openssl rand -base64 48`
#
# STORE THIS OUTSIDE THIS CLUSTER (password manager, etc). It is not derivable from the repo, the
# database, or Hetzner — lose it and every backup you hold is permanently unreadable. Changing it
# later means starting a new stanza; it does not re-encrypt existing backups.
pgbackrest_cipher_pass: CHANGEME_run_openssl_rand_base64_48
