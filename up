#!/usr/bin/env bash
# Build the whole cluster, or one step of it.
#
#   ./up              every step, in order (this is the hands-free path)
#   ./up init         write the config/secret files, asking only for what can't be generated
#   ./up check        preflight only — tools, config files, tokens
#   ./up k0s          just that step; the rest are listed in STEPS below
#   ./up k0s stateful several steps, in the order you name them
#   ./up --yes        don't prompt on `terraform apply`
#
# Steps are individually re-runnable and (bar `terraform apply` prompts) idempotent, so a failed run
# resumes with `./up <the-step-that-failed>` rather than starting over. The long-form commands and
# what each one does: docs/BUILD.md.
set -euo pipefail
cd "$(dirname "$0")"
REPO="$PWD"

STEPS=(init check infra inventory backoffice vpn lb k0s bucket stateful gitops)

TF_APPLY_ARGS=()
[[ "${1:-}" == "--yes" ]] && { TF_APPLY_ARGS=(-auto-approve); shift; }

log()  { printf '\n\033[1;34m==> %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m    %s\033[0m\n' "$*"; }
die()  { printf '\033[1;31mERROR: %s\033[0m\n' "$*" >&2; exit 1; }

# Pull a value back out of a file we (or you) wrote earlier, so re-running init never asks twice.
tfvar_get()   { [[ -f "$1" ]] && grep -oP "^\s*$2\s*=\s*\"\K[^\"]+" "$1" 2>/dev/null | head -1 || true; }
yamlvar_get() { [[ -f "$1" ]] && grep -oP "^\s*$2:\s*\K\S+" "$1" 2>/dev/null | head -1 || true; }

hcloud_token() { echo "${HCLOUD_TOKEN:-$(tfvar_get terraform/secrets.auto.tfvars hcloud_token)}"; }

# ansible-vault: only pass --ask-vault-pass when the file is actually encrypted, so an unencrypted
# (but gitignored, 0600) secrets.yml — what `init` writes — doesn't stall an unattended run on a
# prompt for a password that doesn't exist.
vault_args() {
  [[ -n "${ANSIBLE_VAULT_PASSWORD_FILE:-}" ]] && return 0
  head -c 14 "$REPO/$1" 2>/dev/null | grep -q '^\$ANSIBLE_VAULT' && echo --ask-vault-pass
  return 0
}

# ansible.cfg (inventory path, ssh key, remote_user) is only picked up when cwd is ansible/.
play() { ( cd "$REPO/ansible" && ansible-playbook "$@" ); }

# ---- init ---------------------------------------------------------------------------------------
# Writes every config/secret file the build needs. Existing files are never touched, so this is safe
# to re-run and safe to hand-edit around.
#
# Only three things genuinely can't be generated — they're minted in a web console and have no API:
# the Hetzner API token, the Cloudflare API token, and the Hetzner Object Storage keys. Everything
# else (SSH keypair, VRRP password, backup cipher passphrase) is generated here, because a value
# nobody chose is a value nobody can leak by reusing it from somewhere else.

ask()        { local v; read -rp "    $1: " v || die "no input for '$1' — run ./up init on a terminal"; printf '%s' "$v"; }
ask_secret() { local v; read -rsp "    $1: " v || die "no input for '$1' — run ./up init on a terminal"; echo >&2; printf '%s' "$v"; }
gen()        { openssl rand -base64 36 | tr -d '/+=' | head -c 32; }

step_init() {
  local wrote=0
  umask 077   # everything below is a secret; also keeps the later-generated ansible/inventory 0600

  if [[ ! -f terraform/secrets.auto.tfvars ]]; then
    log "Hetzner + Cloudflare API tokens"
    warn "Hetzner:    Console -> Security -> API tokens (Read & Write)"
    warn "Cloudflare: dashboard -> My Profile -> API Tokens (Zone:DNS:Edit on your zone)"
    local ht cf
    ht=$(ask_secret "Hetzner Cloud API token")
    cf=$(ask_secret "Cloudflare API token")
    cat > terraform/secrets.auto.tfvars <<EOF
# Written by ./up init. Gitignored. Auto-loaded by terraform.
hcloud_token         = "$ht"
cloudflare_api_token = "$cf"
EOF
    wrote=1
  fi

  if [[ ! -f terraform/terraform.tfvars ]]; then
    log "Domain + location"
    warn "The Cloudflare zone must already exist for this domain — terraform looks it up, not creates it."
    local dom loc
    dom=$(ask "Domain (e.g. example.com)")
    loc=$(ask "Hetzner location [ash]"); loc=${loc:-ash}
    cat > terraform/terraform.tfvars <<EOF
# Written by ./up init.
domain   = "$dom"
location = "$loc"
EOF
    wrote=1
  fi

  # ansible.cfg points at ~/.ssh/infra-hetzner; terraform uploads the .pub as the admin key.
  if [[ ! -f terraform/ssh_keys/admin.pub ]]; then
    log "SSH keypair"
    if [[ ! -f ~/.ssh/infra-hetzner ]]; then
      ssh-keygen -t ed25519 -N '' -C 'k0s-hetzner-admin' -f ~/.ssh/infra-hetzner
    else
      warn "reusing existing ~/.ssh/infra-hetzner"
    fi
    cp ~/.ssh/infra-hetzner.pub terraform/ssh_keys/admin.pub
    wrote=1
  fi

  # The same S3 keys are needed in two places: terraform makes the bucket, pgBackRest writes to it.
  # Ask once, write both.
  if [[ ! -f terraform/backups/terraform.tfvars || ! -f ansible/playbooks/postgres/secrets.yml ]]; then
    local ak sk had_bucket=0 bucket
    [[ -f terraform/backups/terraform.tfvars ]] && had_bucket=1   # a repo may already exist out there

    # Hetzner Object Storage bucket names are GLOBALLY unique — "db-backups" is taken and apply dies
    # with BucketAlreadyExists. Derive from the domain, which is unique to you by definition. The same
    # name goes to terraform (creates it) and ansible (writes to it), so they cannot drift.
    bucket=$(tfvar_get terraform/backups/terraform.tfvars backup_bucket)
    [[ -n "$bucket" ]] || bucket=$(yamlvar_get ansible/playbooks/postgres/secrets.yml pgbackrest_s3_bucket)
    [[ -n "$bucket" ]] || bucket="db-backups-$(tfvar_get terraform/terraform.tfvars domain | tr -c 'a-z0-9\n' '-' | sed 's/-*$//')"

    ak=$(tfvar_get terraform/backups/terraform.tfvars hetzner_s3_access_key)
    sk=$(tfvar_get terraform/backups/terraform.tfvars hetzner_s3_secret_key)
    if [[ -z "$ak" ]]; then
      ak=$(yamlvar_get ansible/playbooks/postgres/secrets.yml pgbackrest_s3_access_key)
      sk=$(yamlvar_get ansible/playbooks/postgres/secrets.yml pgbackrest_s3_secret_key)
    fi
    if [[ -z "$ak" ]]; then
      log "Hetzner Object Storage keys (for Postgres backups)"
      warn "Console -> Object Storage -> Manage credentials. These are NOT the API token above."
      ak=$(ask_secret "S3 access key")
      sk=$(ask_secret "S3 secret key")
    fi
    [[ -f terraform/backups/terraform.tfvars ]] || { cat > terraform/backups/terraform.tfvars <<EOF
# Written by ./up init. Gitignored. backup_bucket must match pgbackrest_s3_bucket in
# ansible/playbooks/postgres/secrets.yml — Hetzner bucket names are globally unique.
backup_bucket         = "$bucket"
hetzner_s3_access_key = "$ak"
hetzner_s3_secret_key = "$sk"
EOF
      wrote=1; }

    if [[ ! -f ansible/playbooks/postgres/secrets.yml ]]; then
      local cipher; cipher=$(gen)
      cat > ansible/playbooks/postgres/secrets.yml <<EOF
# Written by ./up init. Gitignored. pgbackrest_s3_bucket must match backup_bucket in
# terraform/backups/terraform.tfvars — that module creates it, pgBackRest writes to it.
pgbackrest_s3_access_key: $ak
pgbackrest_s3_secret_key: $sk
pgbackrest_s3_bucket: $bucket
pgbackrest_cipher_pass: $cipher
EOF
      wrote=1
      # This is the one generated secret whose loss is unrecoverable, so it gets said out loud once.
      printf '\n\033[1;31m    !! SAVE THIS OUTSIDE THE CLUSTER — it encrypts every Postgres backup.\n'
      printf '       Without it the backups are permanently unreadable. It is not stored anywhere else.\n'
      printf '       pgbackrest_cipher_pass: %s\033[0m\n' "$cipher"

      # Regenerating this file on an existing setup mints a passphrase that CANNOT read backups made
      # with the old one. Silently swapping the key is how a repo turns into scrap, so say so.
      if (( had_bucket )); then
        printf '\033[1;31m\n    !! The backup bucket was already configured before this run, so a pgBackRest repo may\n'
        printf '       already exist — encrypted with a DIFFERENT passphrase. This new one cannot read it.\n'
        printf '       Restore the original pgbackrest_cipher_pass into that file, or treat the old\n'
        printf '       backups as lost and start a fresh stanza. Do not run ./up stateful until this is\n'
        printf '       settled.\033[0m\n'
      fi
    fi
  fi

  if [[ ! -f ansible/playbooks/loadbalancer/secrets.yml ]]; then
    log "Load balancer secrets"
    local ht; ht=$(hcloud_token)
    [[ -n "$ht" ]] || die "no hetzner token found — delete terraform/secrets.auto.tfvars and re-run ./up init"
    cat > ansible/playbooks/loadbalancer/secrets.yml <<EOF
# Written by ./up init. Gitignored. keepalived_password is generated; the token is the one from
# terraform/secrets.auto.tfvars — failover.sh uses it to move the floating IP.
keepalived_password: $(gen)
hetzner_api_token: $ht
EOF
    wrote=1
  fi

  if (( wrote )); then
    log "Config written. Encrypt the secrets.yml files if you want them at rest:"
    warn "ansible-vault encrypt ansible/playbooks/{loadbalancer,postgres}/secrets.yml"
    warn "./up detects encryption and will ask for the password (or set ANSIBLE_VAULT_PASSWORD_FILE)."
  else
    log "Config already present — nothing to do"
  fi
}

step_check() {
  local missing=0

  for t in terraform ansible-playbook kubectl wg-quick ssh ssh-keygen openssl; do
    command -v "$t" >/dev/null || { warn "missing tool: $t"; missing=1; }
  done

  # Every file the run needs but can't invent. Checked up front: finding out at the postgres step
  # that secrets.yml was never filled in means an hour of provisioning already happened.
  local f
  for f in \
    terraform/terraform.tfvars \
    terraform/secrets.auto.tfvars \
    terraform/ssh_keys/admin.pub \
    terraform/backups/terraform.tfvars \
    ansible/playbooks/loadbalancer/secrets.yml \
    ansible/playbooks/postgres/secrets.yml
  do
    [[ -f "$REPO/$f" ]] || { warn "missing: $f  (run ./up init)"; missing=1; }
  done

  # nfs_ha needs it to attach the DRBD volumes. Read from tfvars so it isn't a second place to set
  # the same token; $HCLOUD_TOKEN still wins if exported.
  [[ -n "$(hcloud_token)" ]] || { warn "no hetzner token in terraform/secrets.auto.tfvars, and HCLOUD_TOKEN unset"; missing=1; }

  (( missing == 0 )) || die "preflight failed — fix the above, then re-run"
  log "preflight OK"
}

step_infra() {
  log "Terraform — Hetzner servers, network, volumes, floating IPs, DNS"
  terraform -chdir=terraform init -input=false
  terraform -chdir=terraform apply -input=false "${TF_APPLY_ARGS[@]}"
}

step_inventory() {
  log "Rendering ansible/inventory from terraform state"
  terraform -chdir=terraform output -raw ansible_inventory > ansible/inventory
  printf '    %s hosts\n' "$(grep -cE '^[0-9]' ansible/inventory)"
}

step_backoffice() {
  log "Backoffice box — WireGuard, fail2ban, ufw"
  play playbooks/backoffice/backoffice_init/playbook.yaml
}

step_vpn() {
  # The private nodes have no public IP: everything after this reaches them through the tunnel.
  # wg-quick names the interface after the file, so ./ansible/wireguard.conf -> `wireguard`.
  if ip link show wireguard >/dev/null 2>&1; then
    log "WireGuard tunnel already up"
  else
    log "Bringing up the WireGuard tunnel (sudo)"
    [[ -f ansible/wireguard.conf ]] || die "ansible/wireguard.conf not found — run ./up backoffice first"
    sudo wg-quick up ./ansible/wireguard.conf
  fi
}

step_lb() {
  log "Load balancers — keepalived, haproxy, NAT-HA"
  play playbooks/loadbalancer/playbook.yaml $(vault_args ansible/playbooks/loadbalancer/secrets.yml)
}

step_k0s() {
  log "k0s — control plane + workers"
  play playbooks/k0s_main/init_k0s/playbook.yaml
  play playbooks/k0s_main/add_managers/playbook.yaml
  play playbooks/k0s_main/add_workers/playbook.yaml
}

step_bucket() {
  # Before postgres: pgBackRest's stanza-create needs the bucket to exist.
  log "Terraform — backup bucket"
  terraform -chdir=terraform/backups init -input=false
  terraform -chdir=terraform/backups apply -input=false "${TF_APPLY_ARGS[@]}"
}

step_stateful() {
  log "Stateful HA — DRBD NFS, Patroni + pgBackRest"
  play playbooks/nfs/nfs_ha/playbook.yaml -e "hcloud_token=$(hcloud_token)"
  play playbooks/postgres/playbook.yaml $(vault_args ansible/playbooks/postgres/secrets.yml)
  log "Node tuning"
  play playbooks/node_swap/playbook.yaml
  play playbooks/node_reservations/playbook.yaml
  play playbooks/log_hardening/playbook.yaml
}

step_gitops() {
  log "GitOps — ArgoCD app-of-apps"
  [[ -f ansible/main_kubeconfig.conf ]] || die "ansible/main_kubeconfig.conf not found — run ./up k0s first"
  # The sealing key must exist before any SealedSecret syncs, or they decrypt to nothing and the apps
  # come up broken. bootstrap.sh can't know whether you've installed yours — see gitops/certs/README.md.
  KUBECONFIG="$REPO/ansible/main_kubeconfig.conf" gitops/bootstrap/bootstrap.sh
}

run() {
  local s
  for s in "$@"; do
    [[ " ${STEPS[*]} " == *" $s "* ]] || die "unknown step: $s (have: ${STEPS[*]})"
  done
  for s in "$@"; do "step_$s"; done
}

if (( $# )); then
  run "$@"
else
  run "${STEPS[@]}"
  log "Done. Watch ArgoCD converge:  KUBECONFIG=$REPO/ansible/main_kubeconfig.conf kubectl get applications -n argocd -w"
fi
